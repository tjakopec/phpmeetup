{
    "name": "phpmeetup/shipping-price-calculator",
    "description": "Stateless REST API for calculating shipping prices for parcels within Croatia",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "api-platform/core": "^4.0",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/yaml": "^7.0",
        "phpstan/phpstan": "^1.10",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.1",
        "nelmio/api-doc-bundle": "^5.10",
        "symfony/twig-bundle": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan-symfony": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "api-platform/symfony": true,
            "phpstan/phpstan": true,
            "symfony/runtime": true
        }
    }
}
